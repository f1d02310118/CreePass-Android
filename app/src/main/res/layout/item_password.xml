<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/bg_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Baris atas: judul + badge kategori -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="Instagram" />

            <!-- Badge kategori -->
            <TextView
                android:id="@+id/tvCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/badge_text"
                tools:text="Sosial Media"
                android:textSize="11sp"
                android:background="@drawable/bg_badge_category"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp" />

            <ImageButton
                android:id="@+id/btnMore"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_expand_more"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/icon_muted"
                android:contentDescription="@string/item_more_desc" />
        </LinearLayout>

        <!-- Divider tipis -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="10dp" />

        <!-- Username -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_person"
                app:tint="@color/icon_muted"
                android:importantForAccessibility="no" />

            <TextView
                android:id="@+id/tvUsername"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_secondary"
                tools:text="user@gmail.com"
                android:textSize="13sp"
                android:layout_marginStart="8dp" />

            <LinearLayout
                android:id="@+id/layoutAction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone"
                android:gravity="end">

                <ImageButton
                    android:id="@+id/btnEdit"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_edit16"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/accent_blue"
                    android:contentDescription="@string/item_edit_desc"
                    android:layout_marginEnd="8dp" />

                <ImageButton
                    android:id="@+id/btnDelete"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_delete16"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/accent_red"
                    android:contentDescription="@string/item_delete_desc" />
            </LinearLayout>
        </LinearLayout>

        <!-- Password -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_lock"
                app:tint="@color/icon_muted"
                android:importantForAccessibility="no" />

            <TextView
                android:id="@+id/tvPassword"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_secondary"
                tools:text="password123"
                android:textSize="14sp"
                android:layout_marginStart="8dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:fontFamily="monospace" />

            <!-- Tombol toggle show/hide -->
            <ImageButton
                android:id="@+id/btnTogglePassword"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_eye_off"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/icon_muted"
                android:contentDescription="@string/item_toggle_desc"
                android:layout_marginStart="4dp" />

            <!-- Tombol copy password -->
            <ImageButton
                android:id="@+id/btnCopyPassword"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_copy"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/badge_text"
                android:contentDescription="@string/item_copy_desc" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>