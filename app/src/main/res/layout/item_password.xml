<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Baris atas: judul + badge kategori -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Instagram"
                android:textColor="#1A1A2E"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Badge kategori -->
            <TextView
                android:id="@+id/tvCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sosial Media"
                android:textColor="#7C3AED"
                android:textSize="11sp"
                android:background="@drawable/bg_badge_category"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp" />

            <ImageButton
                android:id="@+id/btnMore"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_expand_more"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#9E9E9E"
                android:contentDescription="Menu" />
        </LinearLayout>

        <!-- Divider tipis -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0F0F0"
            android:layout_marginBottom="10dp" />

        <!-- Username -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_person"
                app:tint="#9E9E9E" />

            <TextView
                android:id="@+id/tvUsername"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="user@gmail.com"
                android:textColor="#616161"
                android:textSize="13sp"
                android:layout_marginStart="8dp" />

            <LinearLayout
                android:id="@+id/layoutAction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone"
                android:gravity="end">

                <ImageButton
                    android:id="@+id/btnEdit"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_edit16"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="#3B82F6"
                    android:contentDescription="Edit"
                    android:layout_marginEnd="8dp" />

                <ImageButton
                    android:id="@+id/btnDelete"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_delete16"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="#EF4444"
                    android:contentDescription="Delete" />
            </LinearLayout>
        </LinearLayout>

        <!-- Password -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_lock"
                app:tint="#9E9E9E" />

            <TextView
                android:id="@+id/tvPassword"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="password123"
                android:textColor="#616161"
                android:textSize="14sp"
                android:layout_marginStart="8dp"
                android:fontFamily="monospace" />

            <!-- Tombol toggle show/hide -->
            <ImageButton
                android:id="@+id/btnTogglePassword"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_eye_off"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#9E9E9E"
                android:contentDescription="Toggle password"
                android:layout_marginStart="4dp" />

            <!-- Tombol copy password -->
            <ImageButton
                android:id="@+id/btnCopyPassword"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_copy"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#7C3AED"
                android:contentDescription="Salin password" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>