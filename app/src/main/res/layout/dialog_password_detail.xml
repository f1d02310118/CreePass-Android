<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="@color/bg_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header dialog -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/primary_dark"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="20dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_lock"
                app:tint="@color/primary_purple_light"
                android:importantForAccessibility="no" />

            <TextView
                android:id="@+id/tvDialogTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/detail_title"
                android:textColor="@color/text_white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp" />

            <ImageButton
                android:id="@+id/btnCloseDialog"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_close"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/icon_white"
                android:contentDescription="@string/detail_close_desc" />
        </LinearLayout>

        <!-- Konten detail dengan ScrollView -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Kategori -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/detail_category_label"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvDetailCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/badge_text"
                    tools:text="Sosial Media"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="16dp" />

                <!-- Username -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/detail_username_label"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:letterSpacing="0.1" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:id="@+id/tvDetailUsername"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/text_primary"
                        tools:text="user@gmail.com"
                        android:textSize="15sp" />

                    <ImageButton
                        android:id="@+id/btnCopyUsername"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_copy"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="@color/badge_text"
                        android:contentDescription="@string/detail_copy_username_desc" />
                </LinearLayout>

                <!-- Password -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/detail_password_label"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:letterSpacing="0.1" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:id="@+id/tvDetailPassword"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/text_primary"
                        tools:text="password123"
                        android:textSize="15sp"
                        android:fontFamily="monospace" />

                    <ImageButton
                        android:id="@+id/btnToggleDetail"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_eye_off"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="@color/icon_muted"
                        android:contentDescription="@string/item_toggle_desc" />

                    <ImageButton
                        android:id="@+id/btnCopyDetailPassword"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_copy"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="@color/badge_text"
                        android:contentDescription="@string/detail_copy_password_desc" />
                </LinearLayout>

                <!-- URL -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/detail_url_label"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvDetailUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/detail_url_empty"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

</androidx.cardview.widget.CardView>